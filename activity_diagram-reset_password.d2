direction: down

title: "Password Reset Flow" {
  near: top-center
  style.font-size: 24
  style.bold: true
}

start: "" {shape: circle; style.fill: "#263238"; width: 30; height: 30}

u1: "Buka halaman Login" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"; style.border-radius: 8}
u2: "Klik Lupa Password" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"; style.border-radius: 8}
u3: "Input email" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"; style.border-radius: 8}
u4: "Submit\nPOST /auth/forgot-password" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"; style.border-radius: 8}

b1: "Validate\nForgotPasswordDto" {style.fill: "#FFE0B2"; style.stroke: "#E65100"; style.border-radius: 8}
db1: "Query user\nby email" {style.fill: "#C8E6C9"; style.stroke: "#2E7D32"; style.border-radius: 8}

d_email: "Email\nterdaftar?" {shape: diamond; style.fill: "#E8EAF6"; style.stroke: "#5C6BC0"}

b2: "Generate reset code\n(random 6 digit)" {style.fill: "#FFE0B2"; style.stroke: "#E65100"; style.border-radius: 8}
db2: "Update user\npassword_reset_token\npassword_reset_expires" {style.fill: "#C8E6C9"; style.stroke: "#2E7D32"; style.border-radius: 8}

smtp1: "📧 Kirim email\ndengan reset code" {style.fill: "#FCE4EC"; style.stroke: "#C62828"; style.border-radius: 8}

b3: "Return 200 OK\n'Kode telah dikirim'" {style.fill: "#FFE0B2"; style.stroke: "#E65100"; style.border-radius: 8}

# ── Security: same response for non-existent email ──
b3_fake: "Return 200 OK\n'Jika email terdaftar,\nkode akan dikirim'" {
  style.fill: "#FFF9C4"
  style.stroke: "#F57F17"
  style.border-radius: 8
}

note_security: "⚠️ Response identik\nuntuk mencegah\nemail enumeration" {
  style.fill: "#FFF8E1"
  style.stroke: "#FFD54F"
  style.font-size: 11
  style.italic: true
  shape: page
}

# ── Verify Code Phase ──
verify_phase: "🔐 Verify Code" {
  style.fill: "#F8F9FA"
  style.stroke: "#CFD8DC"
  style.border-radius: 12

  v1: "User buka email\n& salin kode" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"; style.border-radius: 8}
  v2: "Input kode di form\nPOST /auth/verify-code" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"; style.border-radius: 8}
  v3: "Query user\nby email + reset_token" {style.fill: "#C8E6C9"; style.stroke: "#2E7D32"; style.border-radius: 8}
  d_code: "Kode cocok &\nbelum expired?" {shape: diamond; style.fill: "#E8EAF6"; style.stroke: "#5C6BC0"}
  v4: "Return 200 OK\n'Kode valid'" {style.fill: "#FFE0B2"; style.stroke: "#E65100"; style.border-radius: 8}

  v1 -> v2
  v2 -> v3
  v3 -> d_code
  d_code -> v4: "ya" {style.stroke: "#2E7D32"}
}

# ── Reset Phase ──
reset_phase: "🔄 Reset Password" {
  style.fill: "#F8F9FA"
  style.stroke: "#CFD8DC"
  style.border-radius: 12

  r1: "Input password baru\n& konfirmasi" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"; style.border-radius: 8}
  r2: "Submit\nPOST /auth/reset-password" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"; style.border-radius: 8}
  r3: "Validate\nResetPasswordDto" {style.fill: "#FFE0B2"; style.stroke: "#E65100"; style.border-radius: 8}
  r4: "bcrypt.hash\n(newPassword)" {style.fill: "#FFE0B2"; style.stroke: "#E65100"; style.border-radius: 8}
  r5: "Update user.password\nClear reset_token\n& expires" {style.fill: "#C8E6C9"; style.stroke: "#2E7D32"; style.border-radius: 8}
  r6: "Return 200 OK\n'Password berhasil direset'" {style.fill: "#FFE0B2"; style.stroke: "#E65100"; style.border-radius: 8}

  r1 -> r2
  r2 -> r3
  r3 -> r4
  r4 -> r5
  r5 -> r6
}

ok_redirect: "✅ Redirect\nke halaman Login" {style.fill: "#C8E6C9"; style.stroke: "#2E7D32"; style.border-radius: 8; style.bold: true}

err_code: "❌ 400 Kode tidak\nvalid / expired" {style.fill: "#FFCDD2"; style.stroke: "#C62828"; style.border-radius: 8}
err_resend: "Opsi kirim\nulang kode" {style.fill: "#FFF9C4"; style.stroke: "#F57F17"; style.border-radius: 8}

end_ok: "" {shape: circle; style.fill: "#2E7D32"; width: 30; height: 30}
end_err: "" {shape: circle; style.fill: "#C62828"; width: 30; height: 30}

# ── Connections ──
start -> u1
u1 -> u2
u2 -> u3
u3 -> u4
u4 -> b1
b1 -> db1
db1 -> d_email

d_email -> b2: "ya" {style.stroke: "#2E7D32"}
d_email -> b3_fake: "tidak" {style.stroke: "#FF9800"}

b2 -> db2
db2 -> smtp1
smtp1 -> b3
b3 -> verify_phase.v1

b3_fake -> note_security

verify_phase.v4 -> reset_phase.r1
verify_phase.d_code -> err_code: "tidak" {style.stroke: "#C62828"}

reset_phase.r6 -> ok_redirect

ok_redirect -> end_ok
err_code -> err_resend
err_resend -> end_err